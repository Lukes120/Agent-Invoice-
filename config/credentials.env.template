# ============================================================
# CONFIGURAZIONE ODOO - RIEMPIRE CON I DATI DELLA TUA ISTANZA
# ============================================================
# Rinominare questo file in "credentials.env" e compilare i valori.
# NON committare mai il file credentials.env in git.

# URL della tua istanza Odoo (senza slash finale)
ODOO_URL=https://tuaazienda.odoo.com

# Nome del database Odoo
ODOO_DB=nome_database

# Utente dedicato all'agent (consigliato: creare utente "agent_matching" con permessi sola lettura)
ODOO_USERNAME=agent_matching@tuazienda.it

# Password o API key dell'utente
ODOO_PASSWORD=xxxxxxxxxxxxxxxx

# Compagnia (se multi-company, altrimenti lasciare 1)
ODOO_COMPANY_ID=1

# ============================================================
# WEBAPP - Host e porta della dashboard Flask
# ============================================================
# In locale: lasciare i default (127.0.0.1:5000)
# Sul server: impostare 0.0.0.0 e 80 per esporre sulla rete aziendale
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=5000
